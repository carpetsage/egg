{
    "name": "WASMEGG",
    "build": {
        "dockerfile": "Containerfile",
        "args": {}
    },
    "remoteUser": "dev",
    "remoteEnv": {
        "CLAUDE_CONFIG_DIR": "/opt/.claude"
    },
    "customizations": {
        
        "vscode": {
            "extensions": [
                "vue.volar",
                "pbkit.vscode-pbkit"
            ]
        }
    },
    "features": {
        "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
    },
    "mounts": [
        "source=claude-code-config,target=/opt/.claude,type=volume"
    ]
}